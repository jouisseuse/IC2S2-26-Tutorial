# LLM provider API keys.
# Leave these blank if you are using mock models.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Optional LiteLLM-compatible endpoint.
LITELLM_BASE_URL=
LITELLM_API_KEY=

# Default model name used by examples when no model is specified.
DEFAULT_MODEL=

# Mock models are the default for tutorials.
# This lets participants run examples without paid API access.
USE_MOCK_MODEL=true

# Log prompts, raw responses, parsed actions, and model metadata.
LOG_LLM_CALLS=true

# Never commit a real .env file.
