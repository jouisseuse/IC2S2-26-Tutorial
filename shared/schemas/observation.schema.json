{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jouisseuse.github.io/multiplayer-experiment-framework/schemas/observation.schema.json",
  "title": "Observation",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "observation_id",
    "actor_id",
    "actor_type",
    "game_id",
    "group_id",
    "round",
    "stage",
    "observation",
    "timestamp"
  ],
  "properties": {
    "observation_id": { "type": "string" },
    "actor_id": { "type": "string" },
    "actor_type": {
      "type": "string",
      "enum": ["human", "llm", "scripted", "random"]
    },
    "game_id": { "type": "string" },
    "group_id": { "type": "string" },
    "round": { "type": "integer", "minimum": 0 },
    "stage": { "type": "string" },
    "treatment": { "type": ["string", "null"] },
    "observation": { "type": "object" },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}

