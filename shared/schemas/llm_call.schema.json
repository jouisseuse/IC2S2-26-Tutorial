{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jouisseuse.github.io/multiplayer-experiment-framework/schemas/llm_call.schema.json",
  "title": "LLMCall",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "llm_call_id",
    "actor_id",
    "model_provider",
    "model_name",
    "prompt_id",
    "system_prompt",
    "user_prompt",
    "raw_response",
    "parsed_action",
    "latency_ms",
    "temperature",
    "max_tokens",
    "timestamp"
  ],
  "properties": {
    "llm_call_id": { "type": "string" },
    "actor_id": { "type": "string" },
    "game_id": { "type": ["string", "null"] },
    "group_id": { "type": ["string", "null"] },
    "round": { "type": ["integer", "null"], "minimum": 0 },
    "stage": { "type": ["string", "null"] },
    "model_provider": { "type": "string" },
    "model_name": { "type": "string" },
    "prompt_id": { "type": "string" },
    "system_prompt": { "type": "string" },
    "user_prompt": { "type": "string" },
    "raw_response": { "type": "string" },
    "parsed_action": { "type": ["object", "null"] },
    "latency_ms": { "type": "number", "minimum": 0 },
    "temperature": { "type": ["number", "null"] },
    "max_tokens": { "type": ["integer", "null"], "minimum": 1 },
    "error": { "type": ["string", "null"] },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}

