{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jouisseuse.github.io/multiplayer-experiment-framework/schemas/player.schema.json",
  "title": "Player",
  "type": "object",
  "additionalProperties": true,
  "required": ["actor_id", "actor_type", "game_id", "group_id"],
  "properties": {
    "actor_id": { "type": "string" },
    "actor_type": {
      "type": "string",
      "enum": ["human", "llm", "scripted", "random"]
    },
    "participant_id": { "type": ["string", "null"] },
    "game_id": { "type": "string" },
    "group_id": { "type": "string" },
    "role": { "type": ["string", "null"] },
    "model_profile": { "type": ["string", "null"] },
    "prompt_profile": { "type": ["string", "null"] },
    "created_at": { "type": ["string", "null"], "format": "date-time" }
  }
}

