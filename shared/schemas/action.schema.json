{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jouisseuse.github.io/multiplayer-experiment-framework/schemas/action.schema.json",
  "title": "Action",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "action_id",
    "actor_id",
    "actor_type",
    "game_id",
    "group_id",
    "round",
    "stage",
    "action_type",
    "action_value",
    "is_valid",
    "timestamp"
  ],
  "properties": {
    "action_id": { "type": "string" },
    "actor_id": { "type": "string" },
    "actor_type": {
      "type": "string",
      "enum": ["human", "llm", "scripted", "random"]
    },
    "game_id": { "type": "string" },
    "group_id": { "type": "string" },
    "round": { "type": "integer", "minimum": 0 },
    "stage": { "type": "string" },
    "action_type": { "type": "string" },
    "action_value": {},
    "is_valid": { "type": "boolean" },
    "validation_error": { "type": ["string", "null"] },
    "treatment": { "type": ["string", "null"] },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}

