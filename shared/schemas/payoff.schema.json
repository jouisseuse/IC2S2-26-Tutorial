{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jouisseuse.github.io/multiplayer-experiment-framework/schemas/payoff.schema.json",
  "title": "Payoff",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "payoff_id",
    "actor_id",
    "actor_type",
    "game_id",
    "group_id",
    "round",
    "stage",
    "payoff",
    "timestamp"
  ],
  "properties": {
    "payoff_id": { "type": "string" },
    "actor_id": { "type": "string" },
    "actor_type": {
      "type": "string",
      "enum": ["human", "llm", "scripted", "random"]
    },
    "game_id": { "type": "string" },
    "group_id": { "type": "string" },
    "round": { "type": "integer", "minimum": 0 },
    "stage": { "type": "string" },
    "payoff": { "type": "number" },
    "payoff_components": { "type": ["object", "null"] },
    "treatment": { "type": ["string", "null"] },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}
